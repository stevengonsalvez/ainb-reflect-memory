# ainb-reflect-memory — environment template for the shared Postgres backend.
# Copy to `.env` (git-ignored) and fill from Bitwarden. NEVER commit real values.
#   cp .env.example .env
# None of these are needed for the unit tests (`pytest -m "not integration"`).

# --- Enable the shared backend in reflect-kb (BOTH required to switch on) ---
# Trigger is REFLECT_PG_DSN ONLY (not the generic DATABASE_URL). For WRITES the
# DSN must authenticate as service_role / table owner; `authenticated` is read-only.
REFLECT_PG_DSN=
REFLECT_WORKSPACE_ID=

# --- Migrations / seed / integration tests ---
# Postgres connection string (Supabase: Project Settings -> Database).
DATABASE_URL=
# Optional separate throwaway DB for tests (preferred over DATABASE_URL by tests).
REFLECT_TEST_DATABASE_URL=

# --- Supabase (direct PostgREST/JWT client path) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service-role key — bypasses RLS. Server/worker only; NEVER ship to a client.
SUPABASE_SERVICE_ROLE_KEY=
